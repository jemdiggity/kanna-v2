    "vue-chartjs": "^5",
    "vue-i18n": "^11.3.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.1",
    "@vitejs/plugin-vue": "^5.2.1",
