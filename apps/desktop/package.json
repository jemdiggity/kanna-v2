{
  "name": "@kanna/desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "../../scripts/sync-version.sh && bun run build:daemon && vite",
    "build:daemon": "cd ../../crates/daemon && cargo build && cd ../../crates/kanna-hook && cargo build && ../../scripts/stage-sidecars.sh",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test:e2e": "cd tests/e2e && bun test mock/",
    "test:e2e:real": "cd tests/e2e && bun test real/",
    "test:e2e:all": "cd tests/e2e && bun test"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.0",
